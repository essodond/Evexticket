{
  "expo": {
    "sdkVersion": "54.0.0",
    "name": "EVEX Ticket",
    "slug": "evex-ticket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "reactNativeExperimental": {
      "bridgelessMode": false
    },
    "jsEngine": "jsc",
    "extra": {
      "EXPO_PUBLIC_API_BASE_URL": "http://10.0.203.29:8000",
      "eas": {
        "projectId": "acf02b91-e1aa-4041-b503-e80693a2790a"
      }
    },
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.evex.ticket",
      "infoPlist": {
        "NSCameraUsageDescription": "Cette application nécessite l'accès à la caméra pour scanner les QR codes.",
        "NSPhotoLibraryUsageDescription": "Cette application nécessite l'accès à vos photos pour enregistrer vos billets.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.evex.ticket",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Autorisez EVEX Ticket à enregistrer vos billets dans votre galerie.",
          "savePhotosPermission": "Autorisez EVEX Ticket à enregistrer vos billets dans votre galerie."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#0A84FF",
          "defaultChannel": "default"
        }
      ]
    ]
  }
}
