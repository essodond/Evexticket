# API Django appelee par l'application mobile.
# Ne jamais mettre les identifiants QosPay dans l'app mobile.
EXPO_PUBLIC_API_BASE_URL=https://api.evex-tg.com/api

# Mode test actuel : false permet de réserver sans appeler QOS/Flooz/TMoney.
# Remettre true pour réactiver le parcours de paiement mobile réel.
EXPO_PUBLIC_MOBILE_PAYMENTS_ENABLED=false
