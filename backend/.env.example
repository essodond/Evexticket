# Variables d'environnement pour le backend Django
# Copier ce fichier en .env et remplir les valeurs

# Clé secrète Django (générée automatiquement sur Render)
SECRET_KEY=votre-cle-secrete-ici

# Mode debug (True pour dev, False pour production)
DEBUG=True

# URL de la base de données PostgreSQL
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://user:password@localhost:5432/evexticket

# Autoriser toutes les origines CORS (True pour production mobile)
CORS_ALLOW_ALL=True

# Hosts autorisés (séparés par des virgules)
ALLOWED_HOSTS=["*"]

